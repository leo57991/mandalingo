[sub_resource type="Shader" id="Shader_pixel_floor"]
code = "shader_type spatial;\nrender_mode diffuse_lambert, specular_disabled;\n\nuniform vec4 tile_light : source_color = vec4(0.43, 0.47, 0.39, 1.0);\nuniform vec4 tile_dark : source_color = vec4(0.34, 0.38, 0.32, 1.0);\n\nvoid fragment() {\n\tvec2 tile = floor(UV * vec2(16.0, 12.0));\n\tfloat checker = mod(tile.x + tile.y, 2.0);\n\tALBEDO = mix(tile_light.rgb, tile_dark.rgb, checker);\n\tROUGHNESS = 1.0;\n}\n"

