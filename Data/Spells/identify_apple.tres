[gd_resource type="Resource" script_class="SpellPattern" load_steps=2 format=3]

[ext_resource type="Script" path="res://Scripts/Resources/SpellPattern.gd" id="1_spell"]

[resource]
script = ExtResource("1_spell")
spell_id = &"identify_apple"
spell_name_chinese = "顯形·蘋果"
spell_name_english = "Identify Apple"
required_tocfl_level = "Prep1"
slot_pattern = Array[StringName]([&"DEMONSTRATIVE", &"COPULA", &"TARGET"])
slot_fillers = {
&"COPULA": Array[StringName]([&"shi"]),
&"DEMONSTRATIVE": Array[StringName]([&"zhe"]),
&"TARGET": Array[StringName]([&"pingguo"])
}
